    "Blocks connections that would create loops on the soundcard. Disable only if you know what you're doing." : {
      "comment" : "A description of the safety setting that blocks feedback loops on the soundcard.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Blockiert Verbindungen, die Schleifen auf der Soundkarte erzeugen würden. Nur deaktivieren, wenn du weißt, was du tust."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bloquea conexiones que crearían bucles en la tarjeta de sonido. Desactívalo solo si sabes lo que haces."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bloque les connexions qui créeraient des boucles sur la carte son. Ne désactivez que si vous savez ce que vous faites."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Blocca le connessioni che creerebbero loop sulla scheda audio. Disattiva solo se sai cosa stai facendo."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bloqueia conexões que criariam loops na placa de som. Desative apenas se você souber o que está fazendo."
          }
        }
      }
    },
    "Blocks patches that would create a feedback loop on the soundcard. Disable only if you know what you're doing." : {
      "comment" : "A description of the safety setting.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Blockiert Patches, die eine Rückkopplungsschleife auf der Soundkarte erzeugen würden. Nur deaktivieren, wenn du weißt, was du tust."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bloquea patches que crearían un bucle de realimentación en la tarjeta de sonido. Desactívalo solo si sabes lo que haces."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bloque les patches qui créeraient une boucle de réinjection sur la carte son. Ne désactivez que si vous savez ce que vous faites."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Blocca i patch che creerebbero un loop di feedback sulla scheda audio. Disattiva solo se sai cosa stai facendo."
          }
        },
        "pt-BR" : {
