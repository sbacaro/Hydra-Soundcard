        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El backplane Hydra Engine es un driver BlackHole personalizado. GPL-3.0, igual que Hydra."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le backplane Hydra Engine est un pilote BlackHole personnalisé. GPL-3.0, comme Hydra."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
