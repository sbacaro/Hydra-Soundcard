          }
        }
      }
    },
    "The Out side is announced via SAP and sent as multicast RTP — appears in Dante Controller. Experimental until PTP sync lands." : {
      "comment" : "A tooltip for the AES67 TX toggle.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Ausgangsseite wird per SAP angekündigt und als Multicast-RTP gesendet — erscheint im Dante Controller. Experimentell, bis die PTP-Synchronisierung kommt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El lado de salida se anuncia por SAP y se envía como RTP multicast — aparece en Dante Controller. Experimental hasta que llegue la sincronía PTP."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le côté sortie est annoncé via SAP et envoyé en RTP multicast — apparaît dans Dante Controller. Expérimental jusqu’à l’arrivée de la synchro PTP."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il lato uscita viene annunciato via SAP e inviato come RTP multicast — appare in Dante Controller. Sperimentale finché non arriva la sincronia PTP."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O lado de saída é anunciado via SAP e enviado como RTP multicast — aparece no Dante Controller. Experimental até a sincronia PTP chegar."
          }
        }
      }
    },
    "The standard /Library/Audio/Plug-Ins/VST3 and ~/Library/Audio/Plug-Ins/VST3 folders are always scanned. Add one more here, then Rescan." : {
      "comment" : "A footer for the VST3 folder picker.",
