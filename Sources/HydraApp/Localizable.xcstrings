    "The app keeps playing to its normal output; Hydra gets a tap copy" : {
      "comment" : "A description of how the app is captured.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die App spielt weiter über ihren normalen Ausgang; Hydra erhält eine Abzweig-Kopie"
