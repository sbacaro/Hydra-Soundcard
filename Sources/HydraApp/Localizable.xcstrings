    "Compensates the level loss of app captures. Raise if captured apps sound quieter than interface inputs." : {
      "comment" : "A description of the app capture gain slider.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gleicht den Pegelverlust von App-Aufnahmen aus. Erhöhen, falls aufgenommene Apps leiser klingen als Interface-Eingänge."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Compensa la pérdida de nivel de las capturas de app. Súbelo si las apps capturadas suenan más bajas que las entradas de la interfaz."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Compense la perte de niveau des captures d’app. Augmentez si les apps capturées sont plus faibles que les entrées de l’interface."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Compensa la perdita di livello delle catture app. Alza se le app catturate suonano più basse degli ingressi dell’interfaccia."
          }
        },
