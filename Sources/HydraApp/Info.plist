<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>Hydra</string>
	<key>CFBundleDisplayName</key>
	<string>Hydra</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSMinimumSystemVersion</key>
	<string>$(MACOSX_DEPLOYMENT_TARGET)</string>
	<key>NSHumanReadableCopyright</key>
	<string>Hydra Audio — GPL-3.0. Includes BlackHole (Existential Audio, GPL-3.0). VST®, NDI®, Dante® are trademarks of their respective owners.</string>
	<key>NSPrincipalClass</key>
	<string>NSApplication</string>
	<key>NSHighResolutionCapable</key>
	<true/>
	<!-- Menu-bar-first app: start as an accessory (no Dock icon) so launching at
	     login leaves just the menu bar. A Dock icon + app menu are promoted at
	     runtime while an ordinary window is open (see AppDelegate). -->
	<key>LSUIElement</key>
	<true/>
	<!-- In-app auto-update is handled by Sources/HydraApp/Updater.swift: it
	     polls the latest GitHub Release, verifies the .pkg against its published
	     SHA-256, and installs it via an admin prompt. No third-party framework. -->
	<!-- The audio engine runs in-process and captures the audio of apps the user
	     chooses via Core Audio process taps; this string is shown in the TCC
	     prompt. (Moved here from the old hydrad Info.plist.) -->
	<key>NSAudioCaptureUsageDescription</key>
	<string>Hydra captures the audio of apps you choose so it can be routed in the patch grid.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Hydra finds and connects to your Soundcraft console on the local network to use it as a control surface for your DAW.</string>
</dict>
</plist>
