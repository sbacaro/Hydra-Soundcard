<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleIdentifier</key>
	<string>audio.hydra.daemon</string>
	<key>CFBundleName</key>
	<string>hydrad</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<!-- Background agent: hydrad runs without a Dock icon or menu bar presence.
	     It can still open VST plugin editor windows (accessory activation policy).
	     LSUIElement must live in this Info.plist because the daemon target uses
	     GENERATE_INFOPLIST_FILE = NO, so the INFOPLIST_KEY_LSUIElement build
	     setting is ignored. -->
	<key>LSUIElement</key>
	<true/>
	<key>NSAudioCaptureUsageDescription</key>
	<string>Hydra captures the audio of apps you choose so it can be routed in the patch grid.</string>
</dict>
</plist>
