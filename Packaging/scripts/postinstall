#!/bin/bash
# Hydra Audio — GPL-3.0
# Runs as root after the payload is laid down. Make every Hydra HAL driver — the
# engine-hub driver AND all the Hydra Audio Bridge drivers — root-owned, clear
# their quarantine, then reload coreaudiod so all the devices appear immediately.

HAL="/Library/Audio/Plug-Ins/HAL"

# The engine hub plus every bridge bundle staged by the installer. The glob is
# nullglob-safe via the [ -d ] guard, so a missing bridge is simply skipped.
for DRIVER in \
    "$HAL/HydraVirtualSoundcard.driver" \
    "$HAL"/HydraAudioBridge*.driver
do
    [ -d "$DRIVER" ] || continue
    /usr/sbin/chown -R root:wheel "$DRIVER"
    /bin/chmod -R 755 "$DRIVER"
    /usr/bin/xattr -dr com.apple.quarantine "$DRIVER" 2>/dev/null || true
done

# Reload coreaudiod so it picks up the new HAL plug-ins.
# (launchctl kickstart of coreaudiod is SIP-blocked; killall + KeepAlive relaunch.)
/usr/bin/killall coreaudiod 2>/dev/null || true

exit 0
