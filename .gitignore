.build/
**/xcuserdata/
DerivedData/
Backplane/work/
dist/
*.driver
.swiftpm/
ThirdParty/
# Raw working screenshots — the website ships processed copies in docs/assets/
Screenshots/

# xcodebuild -derivedDataPath build
build/
.xcodebuild/
# Bridge driver build output (dSYMs etc.) — regenerated by Scripts/bridges_install.sh
# and wiped by release.sh's tidy_build(); must never be committed.
.bridgebuild/
# project backups
*.pbxproj.bak
# Generated by XcodeGen (project.yml is the source of truth). Run `xcodegen
# generate` after cloning. If it's still tracked: git rm -r --cached Hydra.xcodeproj
Hydra.xcodeproj/

# Release binaries — published to GitHub Releases, never committed
*.pkg
*.zip
*.dmg
*.app.zip
*.pkg.sha256

# Legacy Sparkle private key (no longer used) — never commit it.
sparkle_private_key*

# Rust target directories
**/target/

# Local modules test directory
Modules/
